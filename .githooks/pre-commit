#!/bin/bash
# Auto-bump version in ingest.py on every commit that includes it.
# Format: YYYY.M.D.N (N increments per day)
#
# Enable with: git config core.hooksPath .githooks
set -euo pipefail

# Note: avoid `big-output | grep -q` under `pipefail` — grep short-circuits and
# the producer gets SIGPIPE, making the pipeline non-zero even on a match. Match
# against captured strings instead.
STAGED_FILES=$(git diff --cached --name-only)
case $'\n'"$STAGED_FILES"$'\n' in
  *$'\n'"ingest.py"$'\n'*) : ;;      # ingest.py is staged — continue
  *) exit 0 ;;                        # not in this commit, skip
esac

# No zero padding: PEP 440 normalizes "2026.07.16" to "2026.7.16" in the built
# metadata, so a padded version makes the packaging check's
# `importlib.metadata.version("gyrus") == ingest.__version__` fail for every
# month and day below ten. `%-m`/`%-d` are honored by both GNU and BSD date.
TODAY=$(date +%Y.%-m.%-d)
# Compute the bump from the STAGED blob, not the worktree, so unstaged edits to
# ingest.py aren't silently pulled into the commit.
STAGED_INGEST=$(git show :ingest.py)
CURRENT=$(printf '%s\n' "$STAGED_INGEST" | grep '__version__' | head -1 | sed 's/.*"\(.*\)"/\1/')

if echo "$CURRENT" | grep -q "^$TODAY"; then
  # Same day — increment sequence number
  SEQ=$(echo "$CURRENT" | awk -F. '{print $NF}')
  NEW_SEQ=$((SEQ + 1))
  NEW_VERSION="$TODAY.$NEW_SEQ"
else
  # New day — start at 1
  NEW_VERSION="$TODAY.1"
fi

# Rewrite the version in the staged blob and re-stage ONLY that change (via the
# index), leaving any unstaged worktree hunks untouched. Also update the
# worktree copy so it stays consistent with the index.
bump_in_index() {
  local path="$1" pattern="$2"
  local staged new hash
  staged=$(git show ":$path")
  new=$(printf '%s\n' "$staged" | sed "$pattern")
  # `$(...)` strips trailing newlines, including the one printf just added, so
  # re-add it here. Using printf '%s' drops the newline every text file needs
  # from both the blob and the worktree, on every commit that bumps.
  hash=$(printf '%s\n' "$new" | git hash-object -w --stdin)
  git update-index --cacheinfo 100644,"$hash","$path"
  # Keep the worktree file in sync (portable in-place edit, no BSD/GNU split).
  printf '%s\n' "$new" > "$path"
}

bump_in_index ingest.py "s/__version__ = \".*\"/__version__ = \"$NEW_VERSION\"/"

# Keep pyproject.toml in lockstep (same date-based scheme)
if git ls-files --error-unmatch pyproject.toml >/dev/null 2>&1; then
  bump_in_index pyproject.toml "s/^version = \".*\"/version = \"$NEW_VERSION\"/"
fi

# Fail loudly if the bump didn't take, rather than committing a stale version.
# Match against the captured blob (no pipe) to avoid the pipefail/SIGPIPE
# false-negative on ingest.py's large output.
STAGED_AFTER=$(git show :ingest.py)
case "$STAGED_AFTER" in
  *"__version__ = \"$NEW_VERSION\""*) : ;;
  *) echo "pre-commit: version bump failed" >&2; exit 1 ;;
esac

echo "Version: $NEW_VERSION"
